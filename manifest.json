{
  "manifest_version": 3,
  "name": "CPBL Live Tracker",
  "version": "2.0.4",
  "description": "即時追蹤中華職棒賽事比分、壘包狀態、投打對決與好壞球數，並於開賽前一小時發送桌面彈窗提醒。",
  "permissions": [
    "alarms",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://*.cpbl.com.tw/*",
    "https://tw.sports.yahoo.com/*"
  ],
  "action": {
    "default_popup": "popup_v3.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}